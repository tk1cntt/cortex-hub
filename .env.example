# ─── Cortex Hub Environment Configuration ─────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── General ───────────────────────────────────────────────
NODE_ENV=production

# ─── Cloudflare ────────────────────────────────────────────
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ─── Domain Configuration (REQUIRED for production deploy) ─
# Replace with your own domain. All subdomains must point to your server.
CORTEX_BASE_DOMAIN=your-domain.com
CORTEX_MCP_URL=https://cortex-mcp.your-domain.com
CORTEX_API_URL=https://cortex-api.your-domain.com
CORTEX_DASHBOARD_URL=https://hub.your-domain.com
CORTEX_LLM_URL=https://cortex-llm.your-domain.com
QDRANT_PUBLIC_URL=https://qdrant.your-domain.com
MEM9_PUBLIC_URL=https://mem9.your-domain.com
DASHBOARD_API_URL=https://api.your-domain.com

# ─── LLM Provider Keys ─────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# ─── Hub MCP API Keys (one per agent) ──────────────────────
# Generate with: openssl rand -hex 32
MCP_API_KEYS=

# ─── Dashboard ─────────────────────────────────────────────
DASHBOARD_SECRET=
DASHBOARD_PORT=3000

# ─── mem9 Configuration ───────────────────────────────────
MEM9_LLM_MODEL=gpt-5.4-mini
MEM9_EMBEDDING_MODEL=gemini-embedding-2-preview
MEM9_EMBEDDING_ENABLED=false  # Set true to auto-embed on index (costs money per run)

# ─── Service URLs (Docker internal networking) ─────────────
# Internal: used by services within the Docker network
GITNEXUS_URL=http://gitnexus:4848
QDRANT_URL=http://qdrant:6333
LLM_PROXY_URL=http://llm-proxy:8317
CLIPROXY_URL=http://llm-proxy:8317
DATABASE_PATH=/app/data/cortex.db

# ─── CLIProxy ──────────────────────────────────────────────
MANAGEMENT_PASSWORD=cortex2026
CLIPROXY_AUTH_DIR=/app/cliproxy-auth
CLIPROXY_MANAGEMENT_KEY=cortex2026
