# ─── Cortex Hub Environment Configuration ─────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── General ───────────────────────────────────────────────
NODE_ENV=production

# ─── Cloudflare ────────────────────────────────────────────
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ─── OpenAI (for mem0 embeddings) ──────────────────────────
OPENAI_API_KEY=sk-...

# ─── Hub MCP API Keys (one per agent) ──────────────────────
# Generate with: openssl rand -hex 32
HUB_API_KEY_ANTIGRAVITY=
HUB_API_KEY_GOCLAW=

# ─── Dashboard ─────────────────────────────────────────────
DASHBOARD_SECRET=
DASHBOARD_PORT=3000

# ─── mem9 Configuration ───────────────────────────────────
GEMINI_API_KEY=
MEM9_LLM_MODEL=gpt-5.4-mini
MEM9_EMBEDDING_MODEL=gemini-embedding-2-preview
MEM9_EMBEDDING_ENABLED=false  # Set true to auto-embed on index (costs money per run)

# ─── Service URLs (for Docker internal networking) ─────────
GITNEXUS_URL=http://gitnexus:4848
MEM0_URL=http://mem0:8080
QDRANT_URL=http://qdrant:6333
DATABASE_PATH=/data/hub.db
