# Cortex Hub — Server Environment
# Copy to .env and fill in actual values

# ── Required ─────────────────────────────────
MANAGEMENT_PASSWORD=           # CLIProxy management key (required, no default)

# ── Gemini (optional, for cloud embeddings) ──
GEMINI_API_KEY=                # Google Gemini API key

# ── Dashboard API ────────────────────────────
PORT=4000
NODE_ENV=production
DATABASE_PATH=/app/data/cortex.db
